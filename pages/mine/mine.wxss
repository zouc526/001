.mine-container {
  background-color: #f5f7fa;
  min-height: 100vh;
  padding: 20rpx;
  font-size: 28rpx;
  padding-bottom: 120rpx;
}

.user-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.avatar-wrap {
  display: flex;
  align-items: center;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f8fb;
  margin-right: 20rpx;
}
.user-text {
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.user-tag {
  font-size: 24rpx;
  color: #999;
}
.edit-btn {
  background: linear-gradient(90deg, #4ECDC4, #44A08D);
  color: #fff;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.add-farm-btn {
  width: 100%;
  background: linear-gradient(90deg, #4ECDC4, #44A08D);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.2);
}

.farm-list {
  margin-bottom: 30rpx;
}
.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #4ECDC4;
  line-height: 36rpx;
}

.farm-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.2s ease;
  position: relative;
  padding-bottom: 70rpx;
}
.farm-card:hover {
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-body {
  font-size: 28rpx;
}
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.info-item {
  display: flex;
  flex-direction: column;
  width: calc(50% - 10rpx);
}
.info-item.intro {
  width: 100%;
}
.label {
  color: #718096;
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}
.value {
  color: #2d3748;
  font-size: 28rpx;
  line-height: 36rpx;
}

.card-opt {
  position: absolute;
  bottom: 30rpx;
  right: 24rpx;
  display: flex;
  gap: 8rpx;
}
.opt-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;         
  background: transparent; 
  box-shadow: none;     
  transition: color 0.2s ease;
  width: auto;
  min-width: 80rpx;
}

.opt-btn.edit {
  color: #666; 
}
.opt-btn.edit:hover {
  color: #4ECDC4; 
  background-color: #f5fcfb; 
}

.opt-btn.delete {
  color: #ff4d4f; 
}
.opt-btn.delete:hover {
  color: #ff7875; 
  background-color: #fff5f5; 
}

.opt-icon {
  margin-top: -1rpx;
  transform: scale(0.9);
}

.menu-group {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1px solid #f5f5f5;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  color: #666;
}
.icon-tip {
  margin-right: 8rpx;
}

.login-btn {
  width: 80%;
  background: linear-gradient(90deg, #4ECDC4, #44A08D);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  margin: 60rpx auto 0;
  display: block;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.2);
}

.bottom-tab {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1px solid #f0f0f0;
  z-index: 999;
}
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.tab-icon {
  font-size: 36rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tab-text {
  font-size: 22rpx;
  color: #999;
}
.tab-text.active {
  color: #4ECDC4;
  font-weight: 600;
}

.logout-btn, .login-btn {
  width: 90%;
  margin: 40rpx auto 0;
  display: block;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.logout-btn {
  background-color: #fff;
  color: #ff4444;
  border: 1rpx solid #ff4444;
}

.login-btn {
  background-color: #66cc99;
  color: #fff;
  border: none;
}